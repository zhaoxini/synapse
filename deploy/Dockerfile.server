# synapse-server image for VPS / docker-compose deploy.
FROM rust:1.85-bookworm AS builder
WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
RUN cargo build --release -p synapse-server

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates libssl3 \
    && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/synapse-server /usr/local/bin/synapse-server
# Claude Code CLI must be provided at runtime (install on host or extend this image).
WORKDIR /workspace
EXPOSE 4173
ENTRYPOINT ["synapse-server"]
